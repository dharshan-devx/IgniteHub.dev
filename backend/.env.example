# -----------------------------------------------------------------------------
# IgniteHub Backend Environment Configuration
# -----------------------------------------------------------------------------

# Application Environment Mode (development or production)
ENVIRONMENT=production

# Server Port (Render automatically sets this, defaults to 8000 locally)
PORT=8000

# PostgreSQL Connection String (Neon DB recommended)
DATABASE_URL=postgresql://contact_submitter:your_password@your_endpoint.neon.tech/neondb?sslmode=require

# Gemini API Key (For IdeaForge++ project generation)
GEMINI_API_KEY=your_gemini_api_key_here

# Allowed CORS Origins (comma-separated, without trailing slashes)
# In production, set this to your Vercel deployment URL
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,https://ignitehub.dev
